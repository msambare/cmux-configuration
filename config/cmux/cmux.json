{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux.schema.json",
  "schemaVersion": 1,

  // cmux-configuration — managed cmux app settings (cmux-only; no personal data; safe to share).

  "app": {
    "appearance": "dark",
    "reorderOnNotification": true
  },

  // Desktop alert + sound when an agent finishes / needs input. 'Glass' = distinct chime
  // (swap for any of: default,Basso,Blow,Bottle,Frog,Funk,Glass,Hero,Morse,Ping,Pop,
  //  Purr,Sosumi,Submarine,Tink,none). Per-agent triggers are wired by cmux hooks (agent phase).
  "notifications": {
    "dockBadge": true,
    "showInMenuBar": true,
    "unreadPaneRing": true,
    "paneFlash": true,
    "sound": "Glass"
  },

  // Sidebar tuned to harmonize with the shared Catppuccin Mocha terminal theme.
  "sidebarAppearance": {
    "matchTerminalBackground": false,
    "tintColor": "#181825",
    "tintOpacity": 0.85
  },

  "workspaceColors": {
    "indicatorStyle": "leftRail",
    "selectionColor": "#313244",
    "notificationBadgeColor": "#f38ba8"
  },

  // Hybrid keybindings: tmux-style Cmd+B (cmd+b) prefix for pane/split/window nav.
  //   Why Cmd (not Ctrl/Option): Cmd is cmux's native chord modifier AND macOS never
  //   sends Cmd to the terminal PTY — so a remote tmux's Ctrl+B/Ctrl+A pass through
  //   untouched (no leak), and Option can't lead a chord (macOS composes it to text).
  // cmux Cmd defaults stay for app-level (palette cmd+shift+p, settings cmd+,, new
  //   workspace cmd+n, switcher cmd+p, find, browser, quit). Sidebar moved cmd+b -> cmd+shift+b
  //   (cmd+b is now the prefix). See docs/keybindings.md.
  // Note: %/" express as shift+5 / shift+' (cmux key grammar has no literal %/").
  "shortcuts": {
    "bindings": {
      "splitRight":            ["cmd+b", "shift+5"],
      "splitDown":             ["cmd+b", "shift+'"],
      "focusLeft":             ["cmd+b", "left"],
      "focusRight":            ["cmd+b", "right"],
      "focusUp":               ["cmd+b", "up"],
      "focusDown":             ["cmd+b", "down"],
      "toggleSplitZoom":       ["cmd+b", "z"],
      "equalizeSplits":        ["cmd+b", "space"],
      "newSurface":            ["cmd+b", "c"],
      "nextSurface":           ["cmd+b", "n"],
      "prevSurface":           ["cmd+b", "p"],
      "selectSurfaceByNumber": ["cmd+b", "1"],
      "closeTab":              ["cmd+b", "x"],
      "renameTab":             ["cmd+b", ","],
      "toggleTerminalCopyMode":["cmd+b", "["],
      "toggleSidebar":         "cmd+shift+b"
    }
  }
}
