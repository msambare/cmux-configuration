{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux.schema.json",
  "schemaVersion": 1,

  // cmux-configuration — managed cmux app settings (cmux-only; no personal data; safe to share).

  "app": {
    "appearance": "dark",
    "reorderOnNotification": true
  },

  // Desktop alert + sound when an agent finishes / needs input. 'Glass' = distinct chime
  // (swap for any of: default,Basso,Blow,Bottle,Frog,Funk,Glass,Hero,Morse,Ping,Pop,
  //  Purr,Sosumi,Submarine,Tink,none). Per-agent triggers are wired by cmux hooks (agent phase).
  "notifications": {
    "dockBadge": true,
    "showInMenuBar": true,
    "unreadPaneRing": true,
    "paneFlash": true,
    "sound": "Glass"
  },

  // Sidebar tuned to harmonize with the shared Catppuccin Mocha terminal theme.
  "sidebarAppearance": {
    "matchTerminalBackground": false,
    "tintColor": "#181825",
    "tintOpacity": 0.85
  },

  "workspaceColors": {
    "indicatorStyle": "leftRail",
    "selectionColor": "#313244",
    "notificationBadgeColor": "#f38ba8"
  },

  // Hybrid keybindings: tmux-style Option+B (opt+b) prefix for pane/split/window nav; cmux Cmd defaults
  // stay for app-level (palette cmd+shift+p, settings cmd+,, sidebar cmd+b, new workspace
  // cmd+n, workspace switcher cmd+p, find, browser, quit). See docs/keybindings.md.
  // Note: %/" express as shift+5 / shift+' (cmux key grammar has no literal %/").
  "shortcuts": {
    "bindings": {
      "splitRight":            ["opt+b", "shift+5"],
      "splitDown":             ["opt+b", "shift+'"],
      "focusLeft":             ["opt+b", "left"],
      "focusRight":            ["opt+b", "right"],
      "focusUp":               ["opt+b", "up"],
      "focusDown":             ["opt+b", "down"],
      "toggleSplitZoom":       ["opt+b", "z"],
      "equalizeSplits":        ["opt+b", "space"],
      "newSurface":            ["opt+b", "c"],
      "nextSurface":           ["opt+b", "n"],
      "prevSurface":           ["opt+b", "p"],
      "selectSurfaceByNumber": ["opt+b", "1"],
      "closeTab":              ["opt+b", "x"],
      "renameTab":             ["opt+b", ","],
      "toggleTerminalCopyMode":["opt+b", "["]
    }
  }
}
